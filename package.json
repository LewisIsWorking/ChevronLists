{
    "name": "chevron-lists",
    "displayName": "Chevron Lists",
    "description": "A powerful markdown list manager with 300+ commands: smart keyboard shortcuts, live decorations, tag filtering, kanban, daily notes, AI assist, and more.",
    "version": "24.0.0",
    "icon": "icon.png",
    "publisher": "lewisisworking",
    "repository": {
        "type": "git",
        "url": "https://github.com/LewisIsWorking/ChevronLists"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": ["Other", "Notebooks", "Keymaps", "Formatters"],
    "keywords": [
        "markdown", "todo", "task", "list", "productivity", "notes", "planner",
        "checklist", "organizer", "tagging", "outline", "kanban", "journal",
        "daily notes", "project management", "task manager", "nested list",
        "bullet journal", "wiki", "writing", "gtd", "getting things done",
        "tags", "filtering", "snippets", "autocomplete", "decoration"
    ],
    "activationEvents": ["onLanguage:markdown"],
    "main": "./dist/extension.js",
    "contributes": {
        "configurationDefaults": {
            "editor.semanticTokenColorCustomizations": {
                "rules": {
                    "chevronHeader": {
                        "foreground": "#E5C07B",
                        "bold": true
                    },
                    "chevronPrefix": {
                        "foreground": "#5C6370",
                        "italic": false
                    },
                    "chevronNumber": {
                        "foreground": "#61AFEF"
                    },
                    "chevronContent": {}
                }
            }
        },
        "configuration": {
            "title": "Chevron Lists",
            "properties": {
                "chevron-lists.listPrefix": {
                    "type": "string",
                    "default": "-",
                    "description": "Prefix character for chevron list items. Default '-' gives '>> -'. Change to '*' for '>> *', etc."
                },
                "chevron-lists.colourPreset": {
                    "type": "string",
                    "default": "default",
                    "enum": ["default","ocean","forest","sunset","monochrome","midnight","rose","autumn","arctic","neon","sepia","custom"],
                      "enumDescriptions": [
                          "Amber headers, grey prefixes, blue numbers",
                          "Teal headers, slate prefixes, cyan numbers",
                          "Green headers, dark prefixes, lime numbers",
                          "Coral headers, orange prefixes, gold numbers",
                          "Bold white headers, grey prefixes, silver numbers",
                          "Purple headers, indigo prefixes, lavender numbers",
                          "Pink headers, mauve prefixes, peach numbers",
                          "Orange headers, brown prefixes, red numbers",
                          "Ice blue headers, cool grey prefixes, white numbers",
                          "Bright green headers, dark prefixes, cyan numbers",
                          "Warm tan headers, brown prefixes, gold numbers",
                          "Clear all preset colours — manage manually via settings"
                      ],
                    "description": "Built-in colour preset for chevron syntax highlighting."
                },
                "chevron-lists.snippetTrigger": {
                    "type": "string",
                    "default": "tab",
                    "enum": ["tab", "ctrl+enter", "none"],
                    "enumDescriptions": [
                        "Press Tab after typing chl or chn to expand (may conflict with Copilot suggestions)",
                        "Press Ctrl+Enter after typing chl or chn to expand (no Copilot conflict)",
                        "Disable keyboard expansion Ã¢â‚¬â€ use Insert Snippet from the command palette"
                    ],
                    "description": "Which key triggers chevron snippet expansion (chl / chn)."
                },
                "chevron-lists.blankLineAfterHeader": {
                    "type": "boolean",
                    "default": false,
                    "description": "Insert a blank line between a '> Header' and the first list item when pressing Enter."
                },
                "chevron-lists.anthropicApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "Anthropic API key for AI Assist commands (CL: Suggest Items, Summarise Section, Expand Item). Get one at https://console.anthropic.com"
                },
                "chevron-lists.dailyNoteTemplate": { "type": "string", "default": "", "description": "Template for new daily notes. Supports {{date}}, {{weekday}}, {{day}} placeholders." },
                "chevron-lists.dailyNotesFolder": {
                    "type": "string",
                    "default": "",
                    "description": "Folder for daily notes created by CL: Open Daily Note. Relative to workspace root, or absolute path. Defaults to workspace root if empty."
                },
                "chevron-lists.autoArchive": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, toggling an item to [x] done automatically moves it to the > Archive section."
                },
                "chevron-lists.templates": {
                    "type": "array",
                    "default": [],
                    "description": "User-defined templates for CL: Insert Template. Each item needs 'name', 'description', and 'body' (VS Code snippet syntax).",
                    "items": {
                        "type": "object",
                        "required": ["name", "description", "body"],
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "description": {
                                "type": "string"
                            },
                            "body": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },

{
    "name": "chevron-lists",
    "displayName": "Chevron Lists",
    "description": "Auto-continues >> - nested blockquote list items on Enter in markdown files",
    "version": "0.6.0",
    "publisher": "lewisisworking",
    "repository": {
        "type": "git",
        "url": "https://github.com/LewisIsWorking/ChevronLists"
    },
    "engines": { "vscode": "^1.85.0" },
    "categories": ["Keymaps"],
    "activationEvents": ["onLanguage:markdown"],
    "main": "./out/extension.js",
    "contributes": {
        "configuration": {
            "title": "Chevron Lists",
            "properties": {
                "chevron-lists.listPrefix": {
                    "type": "string",
                    "default": "-",
                    "description": "Prefix character for chevron list items. Default '-' gives '>> -'. Change to '*' for '>> *', etc."
                },
                "chevron-lists.blankLineAfterHeader": {
                    "type": "boolean",
                    "default": false,
                    "description": "Insert a blank line between a '> Header' and the first list item when pressing Enter."
                }
            }
        },
        "commands": [
            { "command": "chevron-lists.onEnter",           "title": "Chevron Lists: Handle Enter" },
            { "command": "chevron-lists.onTab",             "title": "Chevron Lists: Indent Item" },
            { "command": "chevron-lists.onShiftTab",        "title": "Chevron Lists: Dedent Item" },
            { "command": "chevron-lists.selectSectionItems","title": "Chevron Lists: Select Section Items" }
        ],
        "keybindings": [
            {
                "key": "enter",
                "command": "chevron-lists.onEnter",
                "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !inSnippetMode && editorLangId == 'markdown'"
            },
            {
                "key": "tab",
                "command": "chevron-lists.onTab",
                "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !inSnippetMode && editorLangId == 'markdown'"
            },
            {
                "key": "shift+tab",
                "command": "chevron-lists.onShiftTab",
                "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !inSnippetMode && editorLangId == 'markdown'"
            }
        ],
        "grammars": [
            {
                "path": "./syntaxes/chevron-lists.tmLanguage.json",
                "scopeName": "text.html.markdown.chevron-lists",
                "injectTo": ["text.html.markdown"]
            }
        ]
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "license": "CC-BY-NC-ND-4.0",
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "^20.0.0",
        "typescript": "^5.0.0"
    }
}

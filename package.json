        "keybindings": [
        {
            "command": "chevron-lists.toggleNote",
            "key": "ctrl+alt+n",
            "mac": "cmd+alt+n",
            "when": "editorTextFocus && editorLangId == markdown"
        },
            {
                "key": "enter",
                "command": "chevron-lists.onEnter",
                "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !inSnippetMode && editorLangId == 'markdown'"
            },
            {
                "key": "ctrl+enter",
                "command": "chevron-lists.expandSnippet",
                "when": "editorTextFocus && editorLangId == 'markdown'"
            },
            {
                "key": "tab",
                "command": "chevron-lists.onTab",
                "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !inSnippetMode && !inlineSuggestionVisible && editorLangId == 'markdown'"
            },
            {
                "key": "shift+tab",
                "command": "chevron-lists.onShiftTab",
                "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !inSnippetMode && editorLangId == 'markdown'"
            },
            {
                "key": "ctrl+alt+down",
                "command": "chevron-lists.nextHeader",
                "when": "editorTextFocus && editorLangId == 'markdown'"
            },
            {
                "key": "ctrl+alt+up",
                "command": "chevron-lists.prevHeader",
                "when": "editorTextFocus && editorLangId == 'markdown'"
            }
        ],
        "grammars": [
            {
                "path": "./syntaxes/chevron-lists.tmLanguage.json",
                "scopeName": "text.html.markdown.chevron-lists",
                "injectTo": ["text.html.markdown"]
            }
        ],
        "semanticTokenTypes": [
            {
                "id": "chevronHeader",
                "description": "Chevron section header text (after the > prefix)"
            },
            {
                "id": "chevronPrefix",
                "description": "Chevron punctuation: >, >>, >> -, >> N."
            },
            {
                "id": "chevronNumber",
                "description": "Number in a >> N. numbered item"
            },
            {
                "id": "chevronContent",
                "description": "Item content text in >> - or >> N. lines"
            },
            {
                "id": "chevronLabel",
                "description": "Square bracket labels [LIKE THIS] inside item content"
            }
        ],
        "semanticTokenScopes": [
            {
                "language": "markdown",
                "scopes": {
                    "chevronHeader": ["entity.name.section.chevron", "markup.heading"],
                    "chevronPrefix": ["punctuation.definition.list.chevron"],
                    "chevronNumber": ["constant.numeric.chevron"],
                    "chevronContent": ["string.other.chevron"],
                    "chevronLabel":   ["markup.bold.chevron"]
                }
            }
        ],
        "snippets": [
            {
                "language": "markdown",
                "path": "./snippets/chevron-lists.code-snippets"
            }
        ]
    },
    "scripts": {
        "compile": "tsc --noEmit",
        "bundle": "node esbuild.mjs",
        "bundle:prod": "node esbuild.mjs --production",
        "watch": "tsc -watch -p ./ --noEmit",
        "test": "bun test src/__tests__ --coverage"
    },
